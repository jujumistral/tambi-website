{"version":3,"kind":"Article","sha256":"dce4edf1517a8a3d58abc4bd081668b59711647f0554148fad86dd579cd9c51d","slug":"index","location":"/index.md","dependencies":[],"frontmatter":{"title":"TAMBI: Task-Adaptive Model-Based Inference (just an idea that came to my mind - feel free to change back to Task-Ambiguity)","content_includes_title":false,"keywords":["Uncertainty","Quantification","Reinforcement Learning","Bayesian Inference","Active Inference"],"exports":[{"format":"md","filename":"index.md","url":"/tambi-website//build/index-af5013b8ef9fcd180513ac25c4f98ed4.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Learning the Rules of a Changing World","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"MrgtsRU9xn"}],"identifier":"learning-the-rules-of-a-changing-world","label":"Learning the Rules of a Changing World","html_id":"learning-the-rules-of-a-changing-world","implicit":true,"key":"ppSm2RdHxm"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"strong","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"A Computational Study of Belief, Surprise, and Structural Inference Under Uncertainty","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"adQsvqLNDA"}],"key":"u1DGTuYm2h"}],"key":"CiNL95VyZf"},{"type":"thematicBreak","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"AtLG4meysq"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"This documentation accompanies the TAMBI research project, which investigates how humans infer latent environmental structure under different levels of task ambiguity, and how evolving beliefs guide spatio-temporal action under uncertainty. The study integrates a custom behavioral task, multi-modal physiological recording and multiple questionnaires covering mental health, focusing anxiety. A family of 15 particle-filter based agent models provide a tangible representation of how differences in prior knowledge, cognitive capabilities and decision-making preferences shape behavior in our task. Building up on that, we use armortized bayesian inference to extract four individual parameters that reflect the underlying trait-level differences in behavioral patterns. By correlating(?) these parameters with the questionnaire scores, individual task performace differences and related affective reactions, we build a unified framework for the investigation of how mental health profiles are linked to learning and inference in uncertain dynamic environments.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"fsiSwl5Fa9"}],"key":"SG112vsdcF"},{"type":"heading","depth":2,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"What This Documentation Covers","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"penDHkiGKc"}],"identifier":"what-this-documentation-covers","label":"What This Documentation Covers","html_id":"what-this-documentation-covers","implicit":true,"key":"vNbUnbCvDx"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"This book is organized into five major parts:","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"R3ZnI3ByT3"}],"key":"nraNnEMIHa"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"strong","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"link","url":"theoretical_background.md","position":{"start":{"line":15,"column":1},"end":{"line":15,"colum