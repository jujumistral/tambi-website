:{"line":54,"column":1}},"key":"dcT5ePCUnx"}],"key":"sg7IZtZwvj"},{"type":"paragraph","position":{"start":{"line":56,"column":1},"end":{"line":57,"column":1}},"children":[{"type":"text","value":"Using Amortized Bayesian Inference we estimate four participant-level parameters that reflect\nBy mapping the individual parameter values on questionnaire scores and physiological measures, this approach allows to investigate how individual differences in model parameters relate to trait anxiety and other individual difference variables.","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"YHPrF9x2J3"}],"key":"YRVxodH2W2"},{"type":"thematicBreak","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"zQ2A2dHI4e"},{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"Documentation version: April 2026","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"iyst2Scb7H"}],"key":"mlU1kq7Cc0"}],"key":"gJjzdsLvkJ"}],"key":"Y2AhsHgMQO"}],"key":"G8U5zqTAwB"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"next":{"title":"Overview and Introduction","short_title":"The Task","url":"/task/overview-and-introduction","group":"TAMBI - Documentation"}}},"domain":"http://localhost:3000"}